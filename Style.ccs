body {
    background-color: #f2f2f2;
    font-family: Arial, sans-serif;
}

.card {
    background: white;
    width: 300px;
    padding: 20px;
    margin: 100px auto;
    text-align: center;
    border-radius: 10px;
    box-shadow: 0 0 10px gray;
}

button {
    background: blue;
    color: white;
    padding: 10px 20px;
    border: none;
    border-radius: 5px;
}
